{
  "name": "blog-website-news",
  "version": "1.0.0",
  "description": "A modern, responsive blog website built with HTML, CSS, JavaScript, and Bootstrap",
  "main": "index.html",
  "scripts": {
    "build": "node node_modules/sass/sass.js scss/style.scss style.css --quiet-deps",
    "watch": "node node_modules/sass/sass.js scss/style.scss style.css --watch --quiet-deps",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "collectCoverageFrom": [
      "translate.js"
    ]
  },
  "keywords": [
    "blog",
    "html",
    "css",
    "javascript",
    "bootstrap"
  ],
  "author": "GaberSamir",
  "license": "MIT",
  "dependencies": {
    "bootstrap": "^5.3.8"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "sass": "^1.101.0"
  }
}
